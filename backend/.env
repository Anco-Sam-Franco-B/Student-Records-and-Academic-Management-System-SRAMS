######################################################
# JWT AUTHENTICATION
######################################################
JWT_SECRET=srams
JWT_EXPIRES_IN=7d

REFRESH_TOKEN_SECRET=srams
REFRESH_TOKEN_EXPIRES_IN=30d

######################################################
# SESSION
######################################################
SESSION_SECRET=srams

######################################################
# PASSWORD HASHING
######################################################
BCRYPT_SALT_ROUNDS=12

######################################################
# EMAIL (SMTP)
######################################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=ancosamfranco250@gmail.com
SMTP_PASSWORD=vwmu kdwt hfcu vzog
SMTP_FROM=SRAMS <ancosamfranco250@gmail.com>

######################################################
# FILE UPLOADS
######################################################
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

######################################################
# RATE LIMITING
######################################################
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

######################################################
# CORS
######################################################
CORS_ORIGIN=http://localhost:5173

######################################################
# LOGGING
######################################################
LOG_LEVEL=info

######################################################
# COOKIE
######################################################
